<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>404 — {{.BaseURL}}</title>
  <style>
    :root {
      --bg: #0f2027; --surface: #1a3a2e; --accent: #2ecc71;
      --text: #f0f0f0; --muted: #888; --border: rgba(46,204,113,0.25);
      --font-mono: 'Courier New', monospace;
      --font-body: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: var(--bg); color: var(--text);
      font-family: var(--font-body);
      min-height: 100vh;
      display: flex; flex-direction: column; align-items: center;
      justify-content: center; padding: 32px 20px; text-align: center;
    }
    pre {
      font-family: var(--font-mono); color: var(--accent);
      font-size: 10px; line-height: 1.3; margin-bottom: 16px;
    }
    .icon { font-size: 36px; margin-bottom: 12px; }
    h1 { font-size: 15px; margin-bottom: 8px; }
    p { color: var(--muted); font-size: 12px; line-height: 1.7; margin-bottom: 24px; }
    a {
      display: inline-flex; align-items: center; gap: 6px;
      background: var(--surface); color: var(--accent);
      font-size: 12px; padding: 8px 20px; border-radius: 8px;
      text-decoration: none; border: 1px solid var(--border);
    }
    a:hover { background: rgba(46,204,113,0.15); }
    a svg { width: 13px; height: 13px; }
  </style>
</head>
<body>
  <pre>
  _  _    ___  _  _
 | || |  / _ \| || |
 | || |_| | | | || |_
 |__   _| |_| |__   _|
    |_|  \___/   |_|
  </pre>
  <div class="icon">🔍</div>
  <h1>Package not found</h1>
  <p>
    Looks like this Go package doesn't live here.<br>
    Check the import path or browse available packages.
  </p>
  <a href="/">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
    </svg>
    Browse packages
  </a>
</body>
</html>
